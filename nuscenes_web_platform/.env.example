# NuScenes dataset root (directory containing samples/, sweeps/, v1.0-*/)
NUSCENES_DATAROOT=/path/to/nuscenes

# Meta version folder name, e.g. v1.0-mini or v1.0-trainval
NUSCENES_VERSION=v1.0-mini

# Optional: cache dir for rendered PNGs / clips
NUSCENES_WEB_CACHE_DIR=

# Bind address (local only recommended)
NUSCENES_WEB_HOST=127.0.0.1
NUSCENES_WEB_PORT=8765
